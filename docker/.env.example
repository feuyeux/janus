# Copy this file to .env in the same directory (docker/.env) to override the
# demo credentials used by docker-compose.yml. The .env file itself is
# git-ignored, so local overrides never get committed.
#
# Every variable below has a working default baked into docker-compose.yml,
# so the stack runs out of the box even without a .env file. Override these
# only if you need different values (e.g. to avoid clashing with another
# local Nacos/Grafana instance).

# Nacos v3.x requires a Base64-encoded NACOS_AUTH_TOKEN even when
# NACOS_AUTH_ENABLE=false (a startup-check placeholder, not a real
# credential in that mode). Generate your own with:
#   echo -n "some-random-string-at-least-32-chars" | base64
JANUS_NACOS_AUTH_TOKEN=

# Nacos inner-API identity header pair (also required in standalone mode).
JANUS_NACOS_AUTH_IDENTITY_KEY=
JANUS_NACOS_AUTH_IDENTITY_VALUE=

# Grafana admin login for the local observability stack. Change these if
# you expose Grafana beyond localhost, or keep the stack defaults for a
# throwaway local environment.
JANUS_GRAFANA_ADMIN_USER=
JANUS_GRAFANA_ADMIN_PASSWORD=
